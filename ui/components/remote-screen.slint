import { LineEdit } from "std-widgets.slint";

import { RemoteScreenItem } from "../types.slint";
import { BodyText, Card, Heading } from "./common.slint";
import { ScreenIcon } from "./icons.slint";

export component RemoteScreenCard inherits Card {
    in property <RemoteScreenItem> screen;
    in property <int> screen-index;
    callback open-screen(int, string, string, string);

    min-width: 260px;
    height: 314px;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        ScreenIcon { }

        Heading {
            text: root.screen.name;
        }

        BodyText {
            text: root.screen.original;
        }

        Text {
            text: "Select resolution";
            color: #272b31;
            font-size: 12px;
            vertical-alignment: center;
        }

        HorizontalLayout {
            height: 34px;
            spacing: 8px;

            width-input := LineEdit {
                text: root.screen.selected-width;
                input-type: InputType.number;
                min-width: 0px;
                horizontal-stretch: 1;
            }

            Text {
                width: 10px;
                text: "×";
                color: #5e6672;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            height-input := LineEdit {
                text: root.screen.selected-height;
                input-type: InputType.number;
                min-width: 0px;
                horizontal-stretch: 1;
            }
        }

        Text {
            text: "Refresh rate (Hz)";
            color: #272b31;
            font-size: 12px;
            vertical-alignment: center;
        }

        frame-rate-input := LineEdit {
            text: root.screen.selected-frame-rate;
            input-type: InputType.decimal;
            min-width: 0px;
        }

        Rectangle {
            height: 36px;
            border-radius: 5px;
            background: #d81e06;

            Text {
                text: "Open";
                color: #ffffff;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            TouchArea {
                clicked => {
                    root.open-screen(
                        root.screen-index,
                        width-input.text,
                        height-input.text,
                        frame-rate-input.text,
                    );
                }
            }
        }
    }
}

export component RemoteScreenGrid inherits Rectangle {
    in property <[RemoteScreenItem]> screens;
    callback open-screen(int, string, string, string);

    property <length> card-min-width: 260px;
    property <length> card-preferred-width: 320px;
    property <length> card-height: 314px;
    property <length> card-spacing: 12px;
    property <int> column-count: max(1, floor((root.width + root.card-spacing) / (root.card-preferred-width + root.card-spacing)));
    property <int> row-count: root.screens.length == 0 ? 0 : floor((root.screens.length + root.column-count - 1) / root.column-count);
    property <length> card-width: min(root.card-preferred-width, max(root.card-min-width, root.width));

    height: root.row-count * root.card-height + max(0, root.row-count - 1) * root.card-spacing;

    for screen[index] in root.screens: RemoteScreenCard {
        x: mod(index, root.column-count) * (root.card-width + root.card-spacing);
        y: floor(index / root.column-count) * (root.card-height + root.card-spacing);
        width: root.card-width;
        screen: screen;
        screen-index: index;
        open-screen(i, selected-width, selected-height, selected-frame-rate) => {
            root.open-screen(i, selected-width, selected-height, selected-frame-rate);
        }
    }
}
