import {
    Button,
    LineEdit,
    ProgressIndicator,
    ScrollView,
} from "std-widgets.slint";

import {
    AppPage,
    ConnectedDeviceItem,
    ConnectionRequestItem,
    HostedScreenStreamItem,
    NavigationSection,
    RemoteScreenItem,
} from "./types.slint";
import {
    BodyText,
    Card,
    Heading,
    MutedText,
    OnlineStatus,
    PageHeader,
    VideoDisplaySurface,
} from "./components/common.slint";
import { ErrorIcon, PersonIcon } from "./components/icons.slint";
import { Sidebar } from "./components/sidebar.slint";
import { ConnectedPage } from "./pages/connected.slint";

export {
    AppPage,
    ConnectedDeviceItem,
    ConnectionRequestItem,
    HostedScreenStreamItem,
    NavigationSection,
    RemoteScreenItem,
}from "./types.slint";

export component RabbitWindow inherits Window {
    title: "Rabbit";
    preferred-width: 1000px;
    preferred-height: 680px;
    min-width: 720px;
    min-height: 480px;
    max-width: 100000px;
    background: root.video-fill-window-active ? #17191c : #f7f8fa;

    in property <AppPage> page: AppPage.connect;
    in property <NavigationSection> section: NavigationSection.remote-devices;
    in-out property <string> direct-address: "127.0.0.1";
    in property <string> page-title: "Connect to a device";
    in property <string> page-subtitle: "Enter the server IP address, hostname, or either with a port";
    in property <string> status-text;
    in property <string> stream-settings-error;
    in property <string> local-protocol;
    in property <string> local-port;
    in property <bool> local-server-online;
    in property <string> stream-title;
    in property <string> stream-resolution;
    property <bool> video-fill-window: false;
    property <bool> video-fill-window-active:
        root.page == AppPage.streaming && root.video-fill-window;
    out property <length> video-viewport-x: root.video-fill-window-active
        ? 0px
        : streaming-page.absolute-position.x;
    out property <length> video-viewport-y: root.video-fill-window-active
        ? 0px
        : streaming-page.absolute-position.y + 44px;
    out property <length> video-viewport-width: root.video-fill-window-active
        ? root.width
        : streaming-page.width;
    out property <length> video-viewport-height: root.video-fill-window-active
        ? root.height
        : max(0px, streaming-page.height - 44px);
    out property <bool> video-viewport-visible: root.page == AppPage.streaming;
    in property <[ConnectionRequestItem]> connection-requests;
    in property <[ConnectedDeviceItem]> connected-devices;
    in property <[HostedScreenStreamItem]> hosted-screen-streams;
    in property <[RemoteScreenItem]> remote-screens;

    callback connect(string);
    callback video-frame-available();
    callback select-section(NavigationSection);
    callback decide-request(int, bool);
    callback open-screen(int, string, string, string);
    callback disconnect-remote-session();
    callback stop-hosted-screen-stream(int);
    callback disconnect-device(int);
    callback retry-connect();
    callback stop-stream();

    HorizontalLayout {
        spacing: 0px;

        Sidebar {
            visible: !root.video-fill-window-active;
            local-protocol: root.local-protocol;
            local-port: root.local-port;
            local-server-online: root.local-server-online;
            active-section: root.section;
            select-section(section) => { root.select-section(section); }
        }

        Rectangle {
            min-width: 0px;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: root.video-fill-window-active ? #17191c : #f7f8fa;

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding-left: root.video-fill-window-active ? 0px : 34px;
                padding-right: root.video-fill-window-active ? 0px : 34px;
                padding-top: root.video-fill-window-active ? 0px : 30px;
                padding-bottom: root.video-fill-window-active ? 0px : 30px;
                spacing: root.video-fill-window-active ? 0px : 10px;

                PageHeader {
                    visible: !root.video-fill-window-active;
                    title: root.page-title;
                    subtitle: root.page-subtitle;
                }

                content-area := Rectangle {
                    width: 100%;
                    min-height: 0px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    if root.page == AppPage.connect: VerticalLayout {
                        width: content-area.width;
                        height: content-area.height;
                        spacing: 16px;

                        Card {
                            height: 76px;

                            HorizontalLayout {
                                padding: 14px;
                                spacing: 10px;

                                address-input := LineEdit {
                                    text <=> root.direct-address;
                                    placeholder-text: "IP address, hostname, or either with a port";
                                    horizontal-stretch: 1;
                                    accepted => { root.connect(address-input.text); }
                                }

                                Button {
                                    text: "Connect";
                                    primary: true;
                                    clicked => { root.connect(address-input.text); }
                                }
                            }
                        }

                        Card {
                            height: 96px;

                            HorizontalLayout {
                                padding: 17px;
                                spacing: 13px;

                                OnlineStatus {
                                    online: root.local-server-online;
                                    width: 74px;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;
                                    Heading {
                                        text: "Local server";
                                    }

                                    BodyText {
                                        text: root.local-server-online
                                            ? "Ready to receive direct connection requests"
                                            : "The direct connection listener has stopped";
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 3px;
                                    MutedText {
                                        text: root.local-protocol + " PORT";
                                        horizontal-alignment: right;
                                    }

                                    Text {
                                        text: root.local-port;
                                        color: #087cf0;
                                        font-size: 18px;
                                        font-weight: 700;
                                        horizontal-alignment: right;
                                    }
                                }
                            }
                        }

                        if root.status-text != "": Rectangle {
                            height: 42px;
                            background: #fff1f2;
                            border-color: #ffd7da;
                            border-width: 1px;
                            border-radius: 8px;

                            Text {
                                x: 13px;
                                width: parent.width - 26px;
                                text: root.status-text;
                                color: #c73c47;
                                font-size: 12px;
                                wrap: word-wrap;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }

                    if root.page == AppPage.connecting || root.page == AppPage.stream-request: Card {
                        width: content-area.width;
                        height: content-area.height;

                        VerticalLayout {
                            alignment: center;
                            padding: 50px;
                            spacing: 18px;

                            ProgressIndicator {
                                height: 3px;
                                horizontal-stretch: 1;
                                indeterminate: true;
                            }

                            Heading {
                                text: root.status-text;
                                horizontal-alignment: center;
                            }

                            BodyText {
                                text: root.page == AppPage.connecting
                                    ? "The remote device must accept this connection request."
                                    : "The remote screen will open when its first frame arrives.";
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }

                    if root.page == AppPage.connection-error: Card {
                        width: content-area.width;
                        height: content-area.height;

                        VerticalLayout {
                            alignment: center;
                            padding: 48px;
                            spacing: 15px;

                            ErrorIcon { }

                            Heading {
                                text: root.page-title;
                                horizontal-alignment: center;
                            }

                            BodyText {
                                text: root.status-text;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }

                            Rectangle {
                                height: 2px;
                            }

                            Button {
                                text: "Try again";
                                primary: true;
                                clicked => { root.retry-connect(); }
                            }
                        }
                    }

                    if root.page == AppPage.requests: ScrollView {
                        width: content-area.width;
                        height: content-area.height;

                        VerticalLayout {
                            spacing: 12px;

                            for request[index] in root.connection-requests: Card {
                                height: 112px;

                                HorizontalLayout {
                                    padding: 16px;
                                    spacing: 14px;

                                    PersonIcon { }

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 3px;
                                        Heading {
                                            text: request.name;
                                        }

                                        BodyText {
                                            text: request.address;
                                        }

                                        MutedText {
                                            text: "Requests access to this device";
                                        }
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                    }

                                    Button {
                                        text: "Reject";
                                        clicked => { root.decide-request(index, false); }
                                    }

                                    Button {
                                        text: "Accept";
                                        primary: true;
                                        clicked => { root.decide-request(index, true); }
                                    }
                                }
                            }
                        }
                    }

                    if root.page == AppPage.connected: ConnectedPage {
                        width: content-area.width;
                        height: content-area.height;
                        section: root.section;
                        local-protocol: root.local-protocol;
                        local-port: root.local-port;
                        local-server-online: root.local-server-online;
                        stream-settings-error: root.stream-settings-error;
                        connected-devices: root.connected-devices;
                        hosted-screen-streams: root.hosted-screen-streams;
                        remote-screens: root.remote-screens;
                        disconnect-remote-session() => { root.disconnect-remote-session(); }
                        stop-hosted-screen-stream(index) => { root.stop-hosted-screen-stream(index); }
                        disconnect-device(index) => { root.disconnect-device(index); }
                        open-screen(index, selected-width, selected-height, selected-frame-rate) => {
                            root.open-screen(index, selected-width, selected-height, selected-frame-rate);
                        }
                    }

                    streaming-page := VerticalLayout {
                        visible: root.page == AppPage.streaming;
                        width: content-area.width;
                        height: content-area.height;
                        spacing: root.video-fill-window-active ? 0px : 10px;

                        HorizontalLayout {
                            visible: !root.video-fill-window-active;
                            height: 34px;
                            spacing: 8px;

                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: #19b768;
                            }

                            Text {
                                text: "Streaming";
                                color: #16a45d;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Button {
                                text: "Fill window";
                                clicked => { root.video-fill-window = true; }
                            }

                            Button {
                                text: "Stop screen";
                                clicked => { root.stop-stream(); }
                            }
                        }

                        video-surface := VideoDisplaySurface {
                            width: 100%;
                            vertical-stretch: 1;
                            border-radius: root.video-fill-window-active ? 0px : 10px;
                        }
                    }

                    if root.page == AppPage.stream-error: Card {
                        width: content-area.width;
                        height: content-area.height;

                        VerticalLayout {
                            alignment: center;
                            padding: 48px;
                            spacing: 15px;

                            ErrorIcon { }

                            Heading {
                                text: "Screen stream unavailable";
                                horizontal-alignment: center;
                            }

                            BodyText {
                                text: root.status-text;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }

                            Rectangle {
                                height: 2px;
                            }

                            Button {
                                text: "Stop and return";
                                clicked => { root.stop-stream(); }
                            }
                        }
                    }
                }
            }
        }
    }
}
