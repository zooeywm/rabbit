import {
    Button,
    LineEdit,
    ProgressIndicator,
    ScrollView,
} from "std-widgets.slint";

export enum AppPage {
    connect,
    connecting,
    connection-error,
    requests,
    connected,
    stream-request,
    streaming,
    stream-error,
}

export enum NavigationSection {
    remote-devices,
    this-device,
}

export struct ConnectionRequestItem {
    name: string,
    address: string,
}

export struct ConnectedDeviceItem {
    name: string,
    address: string,
    status: string,
}

export struct HostedScreenStreamItem {
    device-name: string,
    screen-name: string,
}

export struct RemoteScreenItem {
    name: string,
    resolution: string,
}

component Heading inherits Text {
    color: #171b22;
    font-size: 17px;
    font-weight: 700;
    vertical-alignment: center;
}

component BodyText inherits Text {
    color: #5e6672;
    font-size: 13px;
    vertical-alignment: center;
}

component MutedText inherits Text {
    color: #8a919c;
    font-size: 12px;
    vertical-alignment: center;
}

component Card inherits Rectangle {
    background: #ffffff;
    border-color: #e8ebf0;
    border-width: 1px;
    border-radius: 10px;
    drop-shadow-color: #140f172a;
    drop-shadow-blur: 14px;
    drop-shadow-offset-y: 4px;
}

// Defines the video layout region. On Wayland this rectangle is covered by a
// DMA-BUF subsurface; the Slint backend draws into the same region.
component VideoDisplaySurface inherits Rectangle {
    background: #17191c;
    border-radius: 10px;
}

component PersonIcon inherits Rectangle {
    width: 46px;
    height: 46px;
    border-radius: 23px;
    background: #e8f2ff;

    Rectangle {
        x: 18px;
        y: 10px;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: #0b7df1;
    }

    Rectangle {
        x: 12px;
        y: 24px;
        width: 22px;
        height: 13px;
        border-radius: 7px;
        background: #0b7df1;
    }
}

component ScreenIcon inherits Rectangle {
    width: 48px;
    height: 48px;
    border-radius: 24px;
    background: #e8f2ff;

    Rectangle {
        x: 11px;
        y: 11px;
        width: 26px;
        height: 19px;
        border-color: #0b7df1;
        border-width: 2px;
        border-radius: 2px;
    }

    Rectangle {
        x: 22px;
        y: 31px;
        width: 4px;
        height: 5px;
        background: #0b7df1;
    }

    Rectangle {
        x: 17px;
        y: 36px;
        width: 14px;
        height: 2px;
        background: #0b7df1;
    }
}

component ErrorIcon inherits Rectangle {
    width: 56px;
    height: 56px;
    border-radius: 28px;
    background: #ffe8ea;

    Text {
        text: "×";
        color: #ef4753;
        font-size: 32px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component OnlineStatus inherits HorizontalLayout {
    in property <bool> online;
    spacing: 7px;

    Rectangle {
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: root.online ? #19b768 : #e54c57;
    }

    Text {
        text: root.online ? "Online" : "Offline";
        color: root.online ? #16a45d : #d9434e;
        font-size: 12px;
        font-weight: 600;
        vertical-alignment: center;
    }
}

component Sidebar inherits Rectangle {
    in property <string> local-port;
    in property <bool> local-server-online;
    in property <NavigationSection> active-section;
    callback select-section(NavigationSection);

    width: 188px;
    background: #ffffff;
    border-color: #e7e9ed;
    border-width: 1px;

    VerticalLayout {
        width: 100%;
        height: 100%;
        padding: 18px;
        spacing: 12px;

        HorizontalLayout {
            height: 38px;
            spacing: 10px;

            Rectangle {
                width: 28px;
                height: 28px;
                border-radius: 8px;
                background: #087cf0;

                Text {
                    text: "R";
                    color: #ffffff;
                    font-size: 16px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                text: "Rabbit";
                color: #171b22;
                font-size: 15px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        Rectangle {
            height: 40px;
            border-radius: 8px;
            background: root.active-section == NavigationSection.remote-devices ? #eaf3ff : #ffffff;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;

                Rectangle {
                    width: 16px;
                    vertical-stretch: 1;

                    Rectangle {
                        y: (parent.height - self.height) / 2;
                        width: 16px;
                        height: 16px;
                        border-radius: 5px;
                        background: #0b7df1;

                        Rectangle {
                            x: 4px;
                            y: 7px;
                            width: 8px;
                            height: 2px;
                            background: #ffffff;
                        }

                        Rectangle {
                            x: 7px;
                            y: 4px;
                            width: 2px;
                            height: 8px;
                            background: #ffffff;
                        }
                    }
                }

                Text {
                    text: "Remote devices";
                    color: root.active-section == NavigationSection.remote-devices ? #087cf0 : #656d78;
                    font-size: 13px;
                    font-weight: root.active-section == NavigationSection.remote-devices ? 600 : 400;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => { root.select-section(NavigationSection.remote-devices); }
            }
        }

        Rectangle {
            height: 40px;
            border-radius: 8px;
            background: root.active-section == NavigationSection.this-device ? #eaf3ff : #ffffff;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 10px;

                Rectangle {
                    width: 16px;
                    vertical-stretch: 1;

                    Rectangle {
                        y: (parent.height - self.height) / 2;
                        width: 16px;
                        height: 16px;
                        border-radius: 5px;
                        background: #8b929c;

                        Rectangle {
                            x: 4px;
                            y: 4px;
                            width: 8px;
                            height: 2px;
                            background: #ffffff;
                        }

                        Rectangle {
                            x: 4px;
                            y: 8px;
                            width: 6px;
                            height: 2px;
                            background: #ffffff;
                        }
                    }
                }

                Text {
                    text: "This device";
                    color: root.active-section == NavigationSection.this-device ? #087cf0 : #656d78;
                    font-size: 13px;
                    font-weight: root.active-section == NavigationSection.this-device ? 600 : 400;
                    vertical-alignment: center;
                }
            }

            TouchArea {
                clicked => { root.select-section(NavigationSection.this-device); }
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }

        VerticalLayout {
            spacing: 5px;

            MutedText {
                text: "LOCAL SERVER";
                font-size: 10px;
                font-weight: 600;
            }

            OnlineStatus {
                online: root.local-server-online;
                height: 20px;
            }

            HorizontalLayout {
                height: 24px;
                spacing: 6px;
                MutedText {
                    text: "UDP";
                }

                Text {
                    text: root.local-port;
                    color: #087cf0;
                    font-size: 14px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }
    }
}

component PageHeader inherits VerticalLayout {
    in property <string> title;
    in property <string> subtitle;

    height: 62px;
    min-width: 0px;
    spacing: 5px;

    Text {
        text: root.title;
        color: #171b22;
        font-size: 21px;
        font-weight: 700;
        vertical-alignment: center;
    }

    BodyText {
        text: root.subtitle;
        height: 22px;
    }
}

export component RabbitWindow inherits Window {
    title: "Rabbit";
    preferred-width: 1000px;
    preferred-height: 680px;
    min-width: 720px;
    min-height: 480px;
    max-width: 100000px;
    background: root.video-fill-window-active ? #17191c : #f7f8fa;

    in property <AppPage> page: AppPage.connect;
    in property <NavigationSection> section: NavigationSection.remote-devices;
    in-out property <string> direct-address: "127.0.0.1";
    in property <string> page-title: "Connect to a device";
    in property <string> page-subtitle: "Enter the server IP address or IP:port";
    in property <string> status-text;
    in property <string> local-port;
    in property <bool> local-server-online;
    in property <string> stream-title;
    in property <string> stream-resolution;
    property <bool> video-fill-window: false;
    property <bool> video-fill-window-active:
        root.page == AppPage.streaming && root.video-fill-window;
    out property <length> video-viewport-x: root.video-fill-window-active
        ? 0px
        : streaming-page.absolute-position.x;
    out property <length> video-viewport-y: root.video-fill-window-active
        ? 0px
        : streaming-page.absolute-position.y + 44px;
    out property <length> video-viewport-width: root.video-fill-window-active
        ? root.width
        : streaming-page.width;
    out property <length> video-viewport-height: root.video-fill-window-active
        ? root.height
        : max(0px, streaming-page.height - 44px);
    out property <bool> video-viewport-visible: root.page == AppPage.streaming;
    in property <[ConnectionRequestItem]> connection-requests;
    in property <[ConnectedDeviceItem]> connected-devices;
    in property <[HostedScreenStreamItem]> hosted-screen-streams;
    in property <[RemoteScreenItem]> remote-screens;

    callback connect(string);
    callback video-frame-available();
    callback select-section(NavigationSection);
    callback decide-request(int, bool);
    callback open-screen(int);
    callback disconnect-remote-session();
    callback stop-hosted-screen-stream(int);
    callback disconnect-device(int);
    callback retry-connect();
    callback stop-stream();

    HorizontalLayout {
        spacing: 0px;

        Sidebar {
            visible: !root.video-fill-window-active;
            local-port: root.local-port;
            local-server-online: root.local-server-online;
            active-section: root.section;
            select-section(section) => { root.select-section(section); }
        }

        Rectangle {
            min-width: 0px;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: root.video-fill-window-active ? #17191c : #f7f8fa;

            VerticalLayout {
                width: 100%;
                height: 100%;
                padding-left: root.video-fill-window-active ? 0px : 34px;
                padding-right: root.video-fill-window-active ? 0px : 34px;
                padding-top: root.video-fill-window-active ? 0px : 30px;
                padding-bottom: root.video-fill-window-active ? 0px : 30px;
                spacing: root.video-fill-window-active ? 0px : 10px;

                PageHeader {
                    visible: !root.video-fill-window-active;
                    title: root.page-title;
                    subtitle: root.page-subtitle;
                }

                content-area := Rectangle {
                    width: 100%;
                    min-height: 0px;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                if root.page == AppPage.connect: VerticalLayout {
                    width: content-area.width;
                    height: content-area.height;
                    spacing: 16px;

                    Card {
                        height: 76px;

                        HorizontalLayout {
                            padding: 14px;
                            spacing: 10px;

                            address-input := LineEdit {
                                text <=> root.direct-address;
                                placeholder-text: "IP address or IP:port";
                                horizontal-stretch: 1;
                                accepted => { root.connect(address-input.text); }
                            }

                            Button {
                                text: "Connect";
                                primary: true;
                                clicked => { root.connect(address-input.text); }
                            }
                        }
                    }

                    Card {
                        height: 96px;

                        HorizontalLayout {
                            padding: 17px;
                            spacing: 13px;

                            OnlineStatus {
                                online: root.local-server-online;
                                width: 74px;
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 4px;
                                Heading {
                                    text: "Local server";
                                }

                                BodyText {
                                    text: root.local-server-online
                                        ? "Ready to receive direct connection requests"
                                        : "The direct connection listener has stopped";
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 3px;
                                MutedText {
                                    text: "UDP PORT";
                                    horizontal-alignment: right;
                                }

                                Text {
                                    text: root.local-port;
                                    color: #087cf0;
                                    font-size: 18px;
                                    font-weight: 700;
                                    horizontal-alignment: right;
                                }
                            }
                        }
                    }

                    if root.status-text != "": Rectangle {
                        height: 42px;
                        background: #fff1f2;
                        border-color: #ffd7da;
                        border-width: 1px;
                        border-radius: 8px;

                        Text {
                            x: 13px;
                            width: parent.width - 26px;
                            text: root.status-text;
                            color: #c73c47;
                            font-size: 12px;
                            wrap: word-wrap;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                    }
                }

                if root.page == AppPage.connecting || root.page == AppPage.stream-request: Card {
                    width: content-area.width;
                    height: content-area.height;

                    VerticalLayout {
                        alignment: center;
                        padding: 50px;
                        spacing: 18px;

                        ProgressIndicator {
                            height: 3px;
                            horizontal-stretch: 1;
                            indeterminate: true;
                        }

                        Heading {
                            text: root.status-text;
                            horizontal-alignment: center;
                        }

                        BodyText {
                            text: root.page == AppPage.connecting
                                ? "The remote device must accept this connection request."
                                : "The remote screen will open when its first frame arrives.";
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }

                if root.page == AppPage.connection-error: Card {
                    width: content-area.width;
                    height: content-area.height;

                    VerticalLayout {
                        alignment: center;
                        padding: 48px;
                        spacing: 15px;

                        ErrorIcon { }

                        Heading {
                            text: root.page-title;
                            horizontal-alignment: center;
                        }

                        BodyText {
                            text: root.status-text;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            height: 2px;
                        }

                        Button {
                            text: "Try again";
                            primary: true;
                            clicked => { root.retry-connect(); }
                        }
                    }
                }

                if root.page == AppPage.requests: ScrollView {
                    width: content-area.width;
                    height: content-area.height;

                    VerticalLayout {
                        spacing: 12px;

                        for request[index] in root.connection-requests: Card {
                            height: 112px;

                            HorizontalLayout {
                                padding: 16px;
                                spacing: 14px;

                                PersonIcon { }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 3px;
                                    Heading {
                                        text: request.name;
                                    }

                                    BodyText {
                                        text: request.address;
                                    }

                                    MutedText {
                                        text: "Requests access to this device";
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Button {
                                    text: "Reject";
                                    clicked => { root.decide-request(index, false); }
                                }

                                Button {
                                    text: "Accept";
                                    primary: true;
                                    clicked => { root.decide-request(index, true); }
                                }
                            }
                        }
                    }
                }

                if root.page == AppPage.connected: connected-page := Rectangle {
                    width: content-area.width;
                    height: content-area.height;
                    clip: true;

                    connected-scroll := ScrollView {
                        viewport-width: connected-page.width;
                        min-width: 0px;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                        VerticalLayout {
                            width: connected-page.width;
                            spacing: 14px;

                            if root.section == NavigationSection.this-device
                                && root.connected-devices.length == 0
                                && root.hosted-screen-streams.length == 0: Card {
                            height: 108px;

                            VerticalLayout {
                                alignment: center;
                                spacing: 7px;

                                OnlineStatus {
                                    online: root.local-server-online;
                                    height: 20px;
                                }

                                BodyText {
                                    text: root.local-server-online
                                        ? "Listening for incoming connections on UDP " + root.local-port
                                        : "The local connection listener has stopped";
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }

                            if root.connected-devices.length > 0: Heading {
                            text: "Devices accessing this device";
                            height: 28px;
                        }

                            for device[index] in root.connected-devices: Card {
                            height: 92px;

                            HorizontalLayout {
                                padding: 16px;
                                spacing: 14px;

                                PersonIcon { }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;
                                    Heading {
                                        text: device.name;
                                    }

                                    BodyText {
                                        text: device.address;
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                HorizontalLayout {
                                    width: 92px;
                                    spacing: 7px;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: #19b768;
                                    }

                                    Text {
                                        text: device.status;
                                        color: #16a45d;
                                        font-size: 12px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                }

                                Button {
                                    text: "Disconnect";
                                    clicked => { root.disconnect-device(index); }
                                }
                            }
                        }

                            if root.hosted-screen-streams.length > 0: Heading {
                            text: "Outgoing screen streams";
                            height: 28px;
                        }

                            for stream[index] in root.hosted-screen-streams: Card {
                            height: 88px;

                            HorizontalLayout {
                                padding: 16px;
                                spacing: 14px;

                                ScreenIcon { }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 4px;

                                    Heading {
                                        text: stream.screen-name;
                                    }

                                    BodyText {
                                        text: "Sending to " + stream.device-name;
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                }

                                Button {
                                    text: "Stop streaming";
                                    clicked => { root.stop-hosted-screen-stream(index); }
                                }
                            }
                        }

                            if root.remote-screens.length > 0: HorizontalLayout {
                            height: 28px;
                            min-width: 0px;

                            Heading {
                                text: "Remote screens";
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                            }

                            Button {
                                text: "Disconnect";
                                clicked => { root.disconnect-remote-session(); }
                            }
                        }

                            HorizontalLayout {
                            spacing: 12px;

                            for screen[index] in root.remote-screens: Card {
                                min-width: 160px;
                                preferred-width: 220px;
                                height: 194px;
                                horizontal-stretch: 1;

                                VerticalLayout {
                                    alignment: center;
                                    padding: 18px;
                                    spacing: 8px;

                                    ScreenIcon { }

                                    Heading {
                                        text: screen.name;
                                        horizontal-alignment: center;
                                    }

                                    BodyText {
                                        text: screen.resolution;
                                        horizontal-alignment: center;
                                    }

                                    Rectangle {
                                        height: 3px;
                                    }

                                    Button {
                                        text: "Open";
                                        primary: true;
                                        clicked => { root.open-screen(index); }
                                    }
                                }
                            }

                            }
                        }
                    }
                }

                streaming-page := VerticalLayout {
                    visible: root.page == AppPage.streaming;
                    width: content-area.width;
                    height: content-area.height;
                    spacing: root.video-fill-window-active ? 0px : 10px;

                    HorizontalLayout {
                        visible: !root.video-fill-window-active;
                        height: 34px;
                        spacing: 8px;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: #19b768;
                        }

                        Text {
                            text: "Streaming";
                            color: #16a45d;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Fill window";
                            clicked => { root.video-fill-window = true; }
                        }

                        Button {
                            text: "Stop screen";
                            clicked => { root.stop-stream(); }
                        }
                    }

                    video-surface := VideoDisplaySurface {
                        width: 100%;
                        vertical-stretch: 1;
                        border-radius: root.video-fill-window-active ? 0px : 10px;
                    }
                }

                if root.page == AppPage.stream-error: Card {
                    width: content-area.width;
                    height: content-area.height;

                    VerticalLayout {
                        alignment: center;
                        padding: 48px;
                        spacing: 15px;

                        ErrorIcon { }

                        Heading {
                            text: "Screen stream unavailable";
                            horizontal-alignment: center;
                        }

                        BodyText {
                            text: root.status-text;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            height: 2px;
                        }

                        Button {
                            text: "Stop and return";
                            clicked => { root.stop-stream(); }
                        }
                    }
                }
                }
            }
        }
    }
}
